{
  "name": "claude-ralph-agent",
  "version": "0.1.4",
  "description": "Ralph 管理工具 — 安装引导、启动控制台、管理项目",
  "type": "module",
  "author": "sickone075",
  "repository": {
    "type": "git",
    "url": "https://github.com/sickone075/claude-ralph-agent.git"
  },
  "bugs": {
    "url": "https://github.com/sickone075/claude-ralph-agent/issues"
  },
  "homepage": "https://github.com/sickone075/claude-ralph-agent#readme",
  "bin": {
    "ralph": "./dist/bin/ralph.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "tsc && cd dashboard && npm install && npm run build && cd .. && npx esbuild dashboard/server/index.ts --bundle --platform=node --format=cjs --outfile=dist/dashboard-server.cjs --external:express --external:ws --external:chokidar --external:simple-git"
  },
  "files": [
    "dist/",
    "skills/",
    ".claude-plugin/",
    "dashboard/dist/",
    "scripts/ralph/ralph.sh",
    "scripts/ralph/CLAUDE.md",
    "scripts/ralph/prompt.md",
    "scripts/ralph/prd.json.example"
  ],
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "express": "^5.1.0",
    "inquirer": "^12.6.0",
    "open": "^10.1.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "esbuild": "^0.27.3",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
